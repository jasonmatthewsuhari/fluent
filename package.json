{
  "name": "fluent",
  "version": "0.1.0",
  "description": "An open-source desktop AI agent for accessible computer control.",
  "main": "electron/main.cjs",
  "private": true,
  "type": "module",
  "author": "Fluent contributors",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron electron/main.cjs\"",
    "electron": "electron electron/main.cjs",
    "app:typecheck": "tsc --noEmit",
    "sdk:build": "npm --workspace @fluent-ai/sdk run build",
    "sdk:test": "npm --workspace @fluent-ai/sdk run test",
    "typecheck": "npm run app:typecheck && npm run sdk:build",
    "test": "npm run sdk:test",
    "lint": "eslint . --max-warnings=0",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"!node_modules\" \"!dist\" \"!release\" \"!packages/*/dist\"",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "check": "npm run typecheck && npm run test && npm run lint && npm run lint:md && npm run format:check && npm run build && npm run audit:prod",
    "build": "npm run typecheck && vite build",
    "package": "npm run build && electron-builder --dir --publish never",
    "dist": "npm run build && electron-builder --publish never",
    "preview": "vite preview --host 127.0.0.1"
  },
  "build": {
    "appId": "dev.fluent.accessibility",
    "productName": "Fluent",
    "copyright": "Copyright (c) 2026 Fluent contributors",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "LICENSE"
    ],
    "asar": true,
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "${productName}-${version}-win-${arch}-setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-win-${arch}-portable.${ext}"
    },
    "linux": {
      "category": "Utility",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "markdownlint-cli2": "^0.19.1",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite": "^7.1.12",
    "vitest": "^2.1.9",
    "wait-on": "^8.0.1"
  }
}
